pipeline {
    agent any

    environment {
        OUTPUT_DIR   = "${WORKSPACE}/outputs"
        S3_BUCKET    = "locate360"
        AWS_REGION   = "ap-south-1"
        JAVA_HOME    = "/usr/lib/jvm/java-17-openjdk-amd64"
    }

    stages {

        stage('1. Pre-Clean, Clone & Checkout') {
            steps {
                echo '🧹 Cleaning workspace and cloning repo...'
                cleanWs()
                withCredentials([usernamePassword(
                    credentialsId: 'github-credentials',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                )]) {
                    sh '''
                        rm -rf "$WORKSPACE"/* "$WORKSPACE"/.git || true
                        git clone -b Native-dev https://${GIT_USER}:${GIT_PASS}@github.com/Locate360-Repo/Locate360-User-app.git "$WORKSPACE"
                        echo "✅ Branch: $(git -C "$WORKSPACE" branch --show-current)"
                        echo "✅ Latest commit: $(git -C "$WORKSPACE" log --oneline -1)"
                        ls -la "$WORKSPACE"
                        ls -la "$WORKSPACE"/android/
                    '''
                }
            }
        }

        stage('2. Setup Environment') {
            steps {
                echo '⚙️ Verifying Java, Node and Android SDK...'
                sh '''
                    java -version
                    node -v
                    npm -v
                    aws --version || true
                '''
            }
        }

        stage('3. Install Dependencies') {
            steps {
                echo '📦 Installing Node dependencies...'
                sh '''
                    cd "$WORKSPACE"
                    npm install --legacy-peer-deps
                    echo "✅ npm install done"
                '''
            }
        }

        stage('4. Setup Debug Keystore') {
            steps {
                echo '🔑 Generating debug keystore if missing...'
                sh '''
                    mkdir -p "$WORKSPACE"/android/app
                    if [ ! -f "$WORKSPACE"/android/app/debug.keystore ]; then
                        keytool -genkey -v \
                            -keystore "$WORKSPACE"/android/app/debug.keystore \
                            -storepass android \
                            -alias androiddebugkey \
                            -keypass android \
                            -keyalg RSA \
                            -keysize 2048 \
                            -validity 10000 \
                            -dname "CN=Android Debug,O=Android,C=US"
                        echo "✅ debug.keystore created"
                    else
                        echo "✅ debug.keystore already exists"
                    fi
                '''
            }
        }

        stage('5. Verify Android Setup') {
            steps {
                echo '📂 Verifying android folder and gradlew...'
                sh '''
                    SDK_PATH=$(find /usr /opt /home -name "adb" 2>/dev/null | head -1 | sed 's|/platform-tools/adb||')

                    if [ -z "$SDK_PATH" ]; then
                        echo "❌ Android SDK not found!"
                        exit 1
                    fi

                    echo "✅ SDK found at: $SDK_PATH"
                    echo "sdk.dir=$SDK_PATH" > "$WORKSPACE"/android/local.properties
                    echo "✅ local.properties created"

                    if [ ! -f "$WORKSPACE"/android/gradlew ]; then
                        echo "❌ gradlew not found!"
                        exit 1
                    fi
                    chmod +x "$WORKSPACE"/android/gradlew
                    echo "✅ gradlew ready"
                '''
            }
        }

        stage('6. Build APK') {
            steps {
                echo '🏗️ Building Release APK...'
                sh '''
                    cd "$WORKSPACE"/android
                    chmod +x gradlew
