<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-permission android:name="android.permission.INTERNET"/>
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
  <uses-permission android:name="android.permission.VIBRATE"/>
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
  <queries>
    <intent>
      <action android:name="android.intent.action.VIEW"/>
      <category android:name="android.intent.category.BROWSABLE"/>
      <data android:scheme="https"/>
    </intent>
  </queries>
  <application android:name=".MainApplication" android:label="@string/app_name" android:icon="@mipmap/ic_launcher" android:roundIcon="@mipmap/ic_launcher_round" android:allowBackup="true" android:theme="@style/AppTheme" android:supportsRtl="true" android:enableOnBackInvokedCallback="false">
    <meta-data android:name="expo.modules.updates.ENABLED" android:value="false"/>
    <meta-data android:name="expo.modules.updates.EXPO_UPDATES_CHECK_ON_LAUNCH" android:value="ALWAYS"/>
    <meta-data android:name="expo.modules.updates.EXPO_UPDATES_LAUNCH_WAIT_MS" android:value="0"/>
    <activity android:name=".MainActivity" android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|uiMode" android:launchMode="singleTask" android:windowSoftInputMode="adjustResize" android:theme="@style/Theme.App.SplashScreen" android:exported="true" android:screenOrientation="portrait">
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
    </activity>
  </application>


pipeline{
  agent any

  environment {
    S3_BUCKET = 'locate360-apk-storage'
    APK_PATH = 'android/app/build/outputs/apk/release/app-release.apk'
  }

  stages{
    stage('1.Checkout'){
      steps{
        withCredentials([usernamePassword(
          credentialsId: 'github-cred',
          usernameVariable: 'GIT_USER',
          passwordVariable: 'GIT_PASS'
        )]) {
          sh '''
            git clone -b Native-dev https://$GIT_USER:$GIT_PASS@github.com/Locate360-Repo/Locate360-User-app.git .
            git checkout Sivakumar
          '''
        }
      }
    }

    stage('2. npm install'){
      steps{
        sh "npm install --legacy-peer-deps"
      }
    }

    stage('3. prebuild'){
      steps{
        sh "npx expo prebuild --clean"
      }
    }

    stage('4. build apk file'){
      steps{
        sh '''
          cd android
          chmod +x gradlew
          ./gradlew assembleRelease
        '''
      }
    }

    stage('5. Upload APK to S3') {
      steps {
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: 'aws-cred'
        ]]) {
          sh """
            aws s3 cp ${APK_PATH} s3://${S3_BUCKET}/releases/Locate360-${BUILD_NUMBER}.apk
            aws s3 cp ${APK_PATH} s3://${S3_BUCKET}/latest/Locate360-latest.apk
          """
        }
      }
    }
  }
}



pipeline {
    agent any

    environment {
        ANDROID_HOME = "/home/kiaq-lap-73/android-sdk"
        JAVA_HOME = "/usr/lib/jvm/java-17-openjdk-amd64"
        PATH = "${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${ANDROID_HOME}/build-tools/36.0.0:${JAVA_HOME}/bin:${env.PATH}"

        PROJECT_DIR = "/home/kiaq-lap-73/Locate360-User-app"
        OUTPUT_DIR = "/home/kiaq-lap-73/locate360-builds"

        AWS_REGION = "us-east-1"
        S3_BUCKET = "locate360-apk-storage"
    }

    stages {

        stage('1. Checkout') {
            steps {
                sh '''
                    git clone -b Native-dev https://github.com/Locate360-Repo/Locate360-User-app.git .
                    git checkout Sivakumar
                '''
            }
        }

        stage('2. Install Dependencies') {
            steps {
                sh '''
                    cd ${PROJECT_DIR}
                    npm install --legacy-peer-deps
                '''
            }
        }

        stage('3. Expo Prebuild') {
            steps {
                sh '''
                    cd ${PROJECT_DIR}
                    npx expo prebuild --clean
                '''
            }
        }

        stage('4. Setup Debug Keystore') {
            steps {
                sh '''
                    if [ ! -f ${PROJECT_DIR}/android/app/debug.keystore ]; then
                        keytool -genkey -v \
                            -keystore ${PROJECT_DIR}/android/app/debug.keystore \
                            -storepass android \
                            -alias androiddebugkey \
                            -keypass android \
                            -keyalg RSA \
                            -keysize 2048 \
                            -validity 10000 \
                            -dname "CN=Android Debug,O=Android,C=US"
                        echo "✅ debug.keystore created"
                    else
                        echo "✅ debug.keystore already exists"
                    fi
                '''
            }
        }

        stage('5. Clean Build') {
            steps {
                sh '''
                    cd ${PROJECT_DIR}/android
                    chmod +x gradlew
                    ./gradlew clean
                '''
            }
        }

        stage('6. Build APK') {
            steps {
                sh '''
                    cd ${PROJECT_DIR}/android
                    ./gradlew assembleRelease
                '''
            }
        }

        stage('7. Copy Output') {
            steps {
                sh '''
                    mkdir -p ${OUTPUT_DIR}
                    cp ${PROJECT_DIR}/android/app/build/outputs/apk/release/app-release.apk \
                       ${OUTPUT_DIR}/Locate360-User-app.apk
                    ls -lh ${OUTPUT_DIR}
                '''
            }
        }

        stage('8. Upload to S3') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-cred'
                ]]) {
                    sh '''
                        aws s3 cp ${OUTPUT_DIR}/Locate360-User-app.apk \
                        s3://${S3_BUCKET}/releases/Locate360-${BUILD_NUMBER}.apk \
                        --region ${AWS_REGION}

                        aws s3 cp ${OUTPUT_DIR}/Locate360-User-app.apk \
                        s3://${S3_BUCKET}/latest/Locate360-latest.apk \
                        --region ${AWS_REGION}

                        echo "✅ S3 Upload Success"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo '🎉 BUILD SUCCESS! APK S3-la upload ஆச்சு!'
        }
        failure {
            echo '❌ BUILD FAILED - Console logs check பண்ணுங்க!'
        }
        always {
            echo '📋 Pipeline completed.'
        }
    }
}
