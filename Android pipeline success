pipeline {
    agent any

    environment {
        OUTPUT_DIR   = "${WORKSPACE}/outputs"
        S3_BUCKET    = "locate360-apk-storage"
        AWS_REGION   = "us-east-1"
        JAVA_HOME    = "/usr/lib/jvm/java-17-openjdk-amd64"
    }

    stages {

        stage('1. Pre-Clean & Clone') {
            steps {
                echo '🧹 Cleaning workspace and cloning repo...'
                cleanWs()
                withCredentials([usernamePassword(
                    credentialsId: 'github-credentials',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                )]) {
                    sh '''
                        git clone -b Native-dev https://${GIT_USER}:${GIT_PASS}@github.com/Locate360-Repo/Locate360-User-app.git "$WORKSPACE"
                        echo "✅ Branch: $(git -C "$WORKSPACE" branch --show-current)"
                        echo "✅ Latest commit: $(git -C "$WORKSPACE" log --oneline -1)"
                        ls -la "$WORKSPACE"
                        ls -la "$WORKSPACE"/android/
                    '''
                }
            }
        }

        stage('2. Setup Environment') {
            steps {
                echo '⚙️ Verifying Java, Node and Android SDK...'
                sh '''
                    java -version
                    node -v
                    npm -v
                    aws --version || true
                '''
            }
        }

        stage('3. Install Dependencies') {
            steps {
                echo '📦 Installing Node dependencies...'
                sh '''
                    cd "$WORKSPACE"
                    npm install --legacy-peer-deps
                    echo "✅ npm install done"
                '''
            }
        }

        stage('4. Setup Debug Keystore') {
            steps {
                echo '🔑 Generating debug keystore if missing...'
                sh '''
                    mkdir -p "$WORKSPACE"/android/app
                    if [ ! -f "$WORKSPACE"/android/app/debug.keystore ]; then
                        keytool -genkey -v \
                            -keystore "$WORKSPACE"/android/app/debug.keystore \
                            -storepass android \
                            -alias androiddebugkey \
                            -keypass android \
                            -keyalg RSA \
                            -keysize 2048 \
                            -validity 10000 \
                            -dname "CN=Android Debug,O=Android,C=US"
                        echo "✅ debug.keystore created"
                    else
                        echo "✅ debug.keystore already exists"
                    fi
                '''
            }
        }

        stage('5. Verify Android Setup') {
            steps {
                echo '📂 Verifying android folder and gradlew...'
                sh '''
                    SDK_PATH=$(find /usr /opt /home -name "adb" 2>/dev/null | head -1 | sed 's|/platform-tools/adb||')

                    if [ -z "$SDK_PATH" ]; then
                        echo "❌ Android SDK not found!"
                        exit 1
                    fi

                    echo "✅ SDK found at: $SDK_PATH"
                    echo "sdk.dir=$SDK_PATH" > "$WORKSPACE"/android/local.properties
                    echo "✅ local.properties created"

                    if [ ! -f "$WORKSPACE"/android/gradlew ]; then
                        echo "❌ gradlew not found!"
                        exit 1
                    fi
                    chmod +x "$WORKSPACE"/android/gradlew
                    echo "✅ gradlew ready"
                '''
            }
        }

        stage('6. Build APK') {
            steps {
                echo '🏗️ Building Release APK...'
                sh '''
                    cd "$WORKSPACE"/android
                    chmod +x gradlew
                    export GRADLE_OPTS="-Xmx2g -XX:MaxMetaspaceSize=512m"
                    export NODE_BINARY=$(which node)
                    export PATH="$WORKSPACE/node_modules/.bin:$PATH"

                    ./gradlew clean assembleRelease --no-daemon

                    if [ -f app/build/outputs/apk/release/app-release.apk ]; then
                        echo "✅ APK found:"
                        ls -lh app/build/outputs/apk/release/
                    else
                        echo "❌ APK not found!"
                        exit 1
                    fi
                '''
            }
        }

        stage('7. Copy Output Files') {
            steps {
                echo '📁 Copying outputs...'
                sh '''
                    mkdir -p "$WORKSPACE"/outputs
                    cp "$WORKSPACE"/android/app/build/outputs/apk/release/app-release.apk \
                       "$WORKSPACE"/outputs/Locate360-User-app.apk
                    echo "✅ APK copied"
                    ls -lh "$WORKSPACE"/outputs/
                '''
            }
        }

        stage('8. Upload to S3') {
            steps {
                echo '☁️ Uploading APK to S3...'
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials'
                ]]) {
                    sh '''
                        aws s3 cp "$WORKSPACE"/outputs/Locate360-User-app.apk \
                            s3://${S3_BUCKET}/releases/Locate360-${BUILD_NUMBER}.apk \
                            --region ${AWS_REGION}
                        aws s3 cp "$WORKSPACE"/outputs/Locate360-User-app.apk \
                            s3://${S3_BUCKET}/latest/Locate360-latest.apk \
                            --region ${AWS_REGION}
                        echo "✅ Uploaded to S3 successfully"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo """
🎉 BUILD SUCCESS!
APK : ${WORKSPACE}/outputs/Locate360-User-app.apk
S3  : s3://${S3_BUCKET}/releases/Locate360-${BUILD_NUMBER}.apk
"""
        }
        failure {
            echo '❌ BUILD FAILED - Check Jenkins console logs.'
        }
        always {
            echo '🏁 Pipeline completed.'
        }
    }
}
