nano roles/jenkins/tasks/main.yml
---
- name: Remove old Java
  yum:
    name: java-17-amazon-corretto-headless
    state: absent

- name: Download Java 21 RPM
  shell: |
    wget https://corretto.aws/downloads/latest/amazon-corretto-21-x64-linux-jdk.rpm -O /tmp/java21.rpm

- name: Install Java 21 RPM
  shell: |
    yum install -y /tmp/java21.rpm

- name: Add Jenkins Repo
  get_url:
    url: https://pkg.jenkins.io/redhat-stable/jenkins.repo
    dest: /etc/yum.repos.d/jenkins.repo

- name: Add Jenkins GPG Key
  rpm_key:
    key: https://pkg.jenkins.io/redhat-stable/jenkins.io-2023.key
    state: present

- name: Install Jenkins
  yum:
    name: jenkins
    state: present
    update_cache: yes

- name: Reload systemd
  systemd:
    daemon_reload: yes

- name: Start Jenkins
  systemd:
    name: jenkins
    state: restarted
    enabled: yes

- name: Wait for Jenkins
  wait_for:
    port: 8080
    timeout: 60

- name: Get Jenkins Password
  command: cat /var/lib/jenkins/secrets/initialAdminPassword
  register: jenkins_pass

- name: Print Password
  debug:
    msg: "Jenkins Password = {{ jenkins_pass.stdout }}"
ansible-playbook -i inventory.ini site.yml --limit jenkins_server
