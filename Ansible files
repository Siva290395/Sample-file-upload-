nano roles/sonarqube/tasks/main.yml
---
- name: Install Java 21 for SonarQube
  shell: |
    wget https://corretto.aws/downloads/latest/amazon-corretto-21-x64-linux-jdk.rpm -O /tmp/java21.rpm
    yum install -y /tmp/java21.rpm

- name: Set vm.max_map_count
  sysctl:
    name: vm.max_map_count
    value: "524288"
    permanent: yes
    state: present

- name: Download SonarQube
  get_url:
    url: https://binaries.sonarsource.com/Distribution/sonarqube/sonarqube-10.4.1.88267.zip
    dest: /opt/sonarqube.zip

- name: Install unzip
  yum:
    name: unzip
    state: present

- name: Extract SonarQube
  unarchive:
    src: /opt/sonarqube.zip
    dest: /opt/
    remote_src: yes

- name: Create SonarQube User
  user:
    name: sonarqube
    system: yes

- name: Set Permissions
  file:
    path: /opt/sonarqube-10.4.1.88267
    owner: sonarqube
    group: sonarqube
    recurse: yes

- name: Create Systemd Service
  copy:
    dest: /etc/systemd/system/sonarqube.service
    content: |
      [Unit]
      Description=SonarQube
      After=network.target

      [Service]
      Type=forking
      User=sonarqube
      ExecStart=/opt/sonarqube-10.4.1.88267/bin/linux-x86-64/sonar.sh start
      ExecStop=/opt/sonarqube-10.4.1.88267/bin/linux-x86-64/sonar.sh stop
      Restart=always

      [Install]
      WantedBy=multi-user.target

- name: Start SonarQube
  systemd:
    name: sonarqube
    state: started
    enabled: yes
    daemon_reload: yes
