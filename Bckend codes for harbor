pipeline {
    agent any

    environment {
        GITHUB_URL = 'https://github.com/Locate360-Repo/Locate360-Backend-RealtimeService.git'
        IMAGE_NAME = 'real-time'
        HARBOR_URL = '32.199.153.246'
        HARBOR_PATH = '/kow-hqr/gateway-service'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'sivakumar', credentialsId: 'github-credentials', url: "${GITHUB_URL}"
            }
        }

        stage('install dependencies') {
            steps {
                sh "npm install"
            }
        }

        stage('Build docker image') {
            steps {
                sh "docker build -t ${IMAGE_NAME} ."
            }
        }

        stage('docker tag image') {
            steps {
                sh """
                docker tag ${IMAGE_NAME} ${HARBOR_URL}${HARBOR_PATH}:$BUILD_NUMBER
                docker tag ${IMAGE_NAME} ${HARBOR_URL}${HARBOR_PATH}:latest
                """
            }
        }

        stage('push image to harbor') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'kow-hqr', passwordVariable: 'HARBOR_PASSWORD', usernameVariable: 'HARBOR_USERNAME')]) {
                    sh 'echo $HARBOR_PASSWORD | docker login ${HARBOR_URL} -u $HARBOR_USERNAME --password-stdin'
                    sh """
                    docker push ${HARBOR_URL}${HARBOR_PATH}:$BUILD_NUMBER
                    docker push ${HARBOR_URL}${HARBOR_PATH}:latest
                    """
                }
            }
        }

        stage('clean up local docker images') {
            steps {
                sh """
                docker rmi ${IMAGE_NAME}
                docker rmi ${HARBOR_URL}${HARBOR_PATH}:$BUILD_NUMBER
                docker rmi ${HARBOR_URL}${HARBOR_PATH}:latest
                """
            }
        }
    }
}



FROM node:20

WORKDIR /app

COPY package.json ./

RUN npm install

COPY . .

EXPOSE 4015

CMD ["node", "src/server.js"]

