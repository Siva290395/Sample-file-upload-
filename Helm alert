apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: my-alerts
  namespace: monitoring
  labels:
    release: prometheus
spec:
  groups:
  - name: pod-alerts
    rules:
    - alert: PodDown
      expr: kube_pod_status_phase{phase="Failed"} > 0
      for: 1m
      labels:
        severity: critical
      annotations:
        summary: "Pod Down Alert!"
        description: "Pod {{ $labels.pod }} is down!"

    - alert: HighCPU
      expr: rate(container_cpu_usage_seconds_total[5m]) > 0.8
      for: 2m
      labels:
        severity: warning
      annotations:
        summary: "High CPU Usage!"
        description: "CPU 80% cross ஆச்சு!"
