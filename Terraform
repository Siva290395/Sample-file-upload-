# உன் Account ID, User info வரும்
Step 8 — SSH Key Pair Create Pannu (EC2 login-ku)
# AWS-la key pair create pannu
aws ec2 create-key-pair \
  --key-name my-key-pair \
  --query 'KeyMaterial' \
  --output text > ~/.ssh/my-key-pair.pem

# Permission set pannu (MANDATORY!)
chmod 400 ~/.ssh/my-key-pair.pem

# Verify
ls -la ~/.ssh/my-key-pair.pem
